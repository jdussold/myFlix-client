{
  "name": "myflix-client",
  "version": "1.0.0",
  "description": "Using React, build the client-side for an application called myFlix based on its existing server-side code (REST API and database).",
  "scripts": {
    "dev": "parcel src/index.html",
    "build": "parcel build src/index.html --public-url ./",
    "start": "parcel src/index.html",
    "postinstall": "find node_modules -path '*/.claude' -type d -exec rm -rf {} +"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdussold/myFlix-client.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jdussold/myFlix-client/issues"
  },
  "homepage": "https://github.com/jdussold/myFlix-client#readme",
  "dependencies": {
    "@parcel/transformer-sass": "^2.16.4",
    "bootstrap": "^5.3.3",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.7",
    "react-dom": "^18.3.1",
    "react-fontawesome": "^1.7.1",
    "react-router": "^7.15.0",
    "react-router-dom": "^7.15.0",
    "react-spinners": "^0.17.0"
  },
  "devDependencies": {
    "parcel": "^2.13.3"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
